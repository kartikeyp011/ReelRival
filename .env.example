# ─── YouTube ───────────────────────────────
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# ─── Kaggle GPU Services (update every Kaggle session) ──
EMBED_SERVICE_URL=https://xxxx.ngrok-free.app
LLM_SERVICE_URL=https://yyyy.ngrok-free.app

# ─── Kaggle Auth Token (protects your ngrok endpoints) ──
KAGGLE_SERVICE_TOKEN=your_random_secret_token_here

# ─── FAISS + Metadata Paths ─────────────────
FAISS_INDEX_PATH=./data/faiss_index.bin
METADATA_STORE_PATH=./data/metadata_store.json

# ─── Embedding Config ────────────────────────
EMBEDDING_DIM=1024

# ─── Retrieval Config ────────────────────────
TOP_K_CHUNKS=5

# ─── Chat / Memory Config ────────────────────
MAX_MEMORY_TURNS=6

# ─── App Config ──────────────────────────────
APP_ENV=development
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173